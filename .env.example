# Copy this to .env for local dev (Netlify injects real values automatically once deployed + configured)

# Required: get one at https://console.anthropic.com (Settings > API Keys)
ANTHROPIC_API_KEY=

# Required: any password you choose — this is what you and your colleagues will type in to open the app
TEAM_PASSCODE=

# Netlify Blobs works automatically on a deployed Netlify site — no keys needed here.
